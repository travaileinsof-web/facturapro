{
  "version": 2,
  "builds": [
    {
      "src": "backend/api.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "backend/check_db.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "backend/cron_reminders.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/cron/reminders", "destination": "/backend/cron_reminders.php" },
    { "source": "/api/check_db/:path*",  "destination": "/backend/check_db.php" },
    { "source": "/api/:path*",           "destination": "/backend/api.php" }
  ],
  "headers": [
    {
      "source": "/backend/(.*)",
      "headers": [{ "key": "x-robots-tag", "value": "noindex" }]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 8 * * *"
    }
  ]
}
