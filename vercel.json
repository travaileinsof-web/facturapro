{
  "version": 2,
  "builds": [
    {
      "src": "backend/api.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "backend/admin_api.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "backend/check_db.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "backend/cron_reminders.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/admin(.*)",
      "dest": "/backend/admin_api.php"
    },
    {
      "src": "/api/cron/reminders",
      "dest": "/backend/cron_reminders.php"
    },
    {
      "src": "/api/check_db(.*)",
      "dest": "/backend/check_db.php"
    },
    {
      "src": "/api(.*)",
      "dest": "/backend/api.php"
    },
    {
      "src": "/backend/(.*)",
      "status": 403
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 8 * * *"
    }
  ]
}
