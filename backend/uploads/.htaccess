# Désactiver le listage des répertoires pour des raisons de sécurité
Options -Indexes

# Désactiver l'exécution de scripts dans le dossier uploads
<FilesMatch "\.(php|php5|php7|php8|phtml|pl|py|jsp|asp|htm|html|shtml|sh|cgi)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Forcer le type MIME pour éviter l'exécution par le navigateur
ForceType application/octet-stream
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg)$">
    ForceType none
</FilesMatch>
